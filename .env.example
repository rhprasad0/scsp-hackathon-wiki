# llm-wiki-compiler provider configuration
# Fill in locally and keep this file out of git.

# Preferred local route on Ryan's machine:
# a local codex-bridge reuses Codex subscription OAuth and exposes an
# OpenAI-compatible API at http://127.0.0.1:4000/v1.
# To auto-generate a working .env from the local bridge config, run:
#   npm run setup:codex-bridge

LLMWIKI_PROVIDER=openai
OPENAI_API_KEY=YOUR_LOCAL_CODEX_BRIDGE_API_KEY_HERE
OPENAI_BASE_URL=http://127.0.0.1:4000/v1
LLMWIKI_MODEL=gpt-5.4-mini
LLMWIKI_FORCE_NON_STREAMING=1

# Anthropic alternative
# LLMWIKI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
# ANTHROPIC_AUTH_TOKEN=YOUR_ANTHROPIC_AUTH_TOKEN_HERE
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# LLMWIKI_MODEL=claude-sonnet-4-20250514

# Direct OpenAI-compatible alternative
# LLMWIKI_PROVIDER=openai
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLMWIKI_MODEL=gpt-4.1-mini
