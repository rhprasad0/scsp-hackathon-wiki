# llm-wiki-compiler provider configuration
# Fill in locally and keep this file out of git.

# Choose one provider route.
LLMWIKI_PROVIDER=anthropic

# Anthropic (default / easiest if already available)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
# Optional
# ANTHROPIC_AUTH_TOKEN=YOUR_ANTHROPIC_AUTH_TOKEN_HERE
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# LLMWIKI_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible alternative
# LLMWIKI_PROVIDER=openai
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLMWIKI_MODEL=gpt-4.1-mini
